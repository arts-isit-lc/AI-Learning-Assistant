{
  "version": "v1",
  "hooks": [
    {
      "name": "Python Lambda Syntax Check",
      "description": "Checks the saved Python file for syntax errors. Extracts file path from stdin JSON context.",
      "trigger": "PostFileSave",
      "matcher": "cdk/.*\\.py$",
      "action": {
        "type": "command",
        "command": "python3 -c \"import json,sys,py_compile;d=json.load(sys.stdin);py_compile.compile(d.get('filePath',d.get('path','')),doraise=True)\""
      },
      "timeout": 10,
      "enabled": true
    }
  ]
}
