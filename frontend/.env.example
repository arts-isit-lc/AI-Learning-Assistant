# REST API — base URL for all backend calls (set by CDK output)
VITE_API_ENDPOINT=

# AWS region for Cognito auth
VITE_AWS_REGION=

# Cognito User Pool — used for Amplify auth config and JWT verification
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_USER_POOL_CLIENT_ID=

# AppSync — real-time WebSocket for chat streaming and notifications
VITE_GRAPHQL_WS_URL=
VITE_API_KEY=

# OCELIA rebuild (Phase 2+) — set to "true" to load the new Tailwind/shadcn app
# shell (BrowserRouter + role guards + contexts). Unset/anything else = the
# legacy MUI app. Removed in Phase 8 when the rebuild fully ships.
VITE_UI_V2=
